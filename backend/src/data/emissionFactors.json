    "plastic":            { "co2PerItem": 3,   "label": "Plastic Item" },
    "bambooWood":         { "co2PerItem": 1.5, "label": "Bamboo / Wood" },
    "glass":              { "co2PerItem": 2,   "label": "Glass Item" },
    "metal":              { "co2PerItem": 6,   "label": "Metal Item" },
    "paper":              { "co2PerItem": 1,   "label": "Paper / Cardboard" },
    "electronicsSmall":   { "co2PerItem": 8,   "label": "Small Electronics (cable, charger)" },
    "electronicsPhone":   { "co2PerItem": 70,  "label": "Smartphone" },
    "electronicsLaptop":  { "co2PerItem": 300, "label": "Laptop / Computer" },
    "general":            { "co2PerItem": 5,   "label": "General / Unidentified" }
  },

  "foodPerKg": {
    "beef": 60, "lamb": 24, "pork": 7, "poultry": 6, "fish": 5,
    "eggs": 4.5, "cheese": 21, "milk": 3, "rice": 4, "tofu": 3,
    "vegetables": 0.4, "fruit": 0.5, "legumes": 1, "grains": 1.1
