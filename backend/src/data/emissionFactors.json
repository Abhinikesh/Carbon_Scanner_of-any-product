    "general":        { "factorPerDollar": 0.25, "label": "General Retail" }
  },

  "materialCategories": {
    "leather":            { "co2PerItem": 15,  "label": "Leather Goods" },
    "cotton":             { "co2PerItem": 7,   "label": "Cotton Textile" },
